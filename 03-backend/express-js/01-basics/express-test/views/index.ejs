<!DOCTYPE html>
<html>
    <head>
        <title><%= title %></title>
        <!-- This link tests the 'public' static folder -->
        <link rel="stylesheet" href="/style.css" />
    </head>
    <body>
        <h1>
            Hello,
            <%= name %>!
        </h1>
        <p>If you see blue text and a styled page, the static middleware worked.</p>

        <!-- This form tests the URL-encoded middleware -->
        <h2>Test URL-Encoded Form</h2>
        <form action="/test-form" method="POST">
            <input type="text" name="username" placeholder="Enter name" />
            <button type="submit">Submit Form</button>
        </form>
    </body>
</html>
