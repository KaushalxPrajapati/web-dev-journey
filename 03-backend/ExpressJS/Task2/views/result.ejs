<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Result</title>
	<style>
		body {
			display: flex;
			justify-content: center;
		}

		#passed {
			color: green;
		}

		#failed {
			color: red;
		}
	</style>
</head>

<body>
	<% if(marks>=40) { %>
		<h1 id='passed'>You Passed!</h1>
	<% } else { %>
		<h1 id='failed'>You Failed!</h1>
	<% } %>
</body>

</html>