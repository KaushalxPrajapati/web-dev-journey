<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Feed</title>
</head>

<body>
	<% for (let i=0; i<posts.length; i++) { %>
	<p>Post <%= i + 1 %> - <%= posts[i].username %>: <%= posts[i].content %></p>
	<hr>
	<% } %>
</body>

</html>